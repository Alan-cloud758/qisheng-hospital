  body        String   @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DataImportLog {
  id          String   @id @default(cuid())
  importType  String   @db.VarChar(60) // PATIENT / DRUG / SCHEDULE
  fileName    String   @db.VarChar(255)
  totalRows   Int
  successRows Int
