generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum AppointmentSlotStatus {
  AVAILABLE
  LOCKED
  BOOKED
  CANCELLED
}

enum RegistrationStatus {
  BOOKED
  CANCELLED
  CHECKED_IN
  IN_VISIT
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentBusinessType {
  REGISTRATION
  OUTPATIENT
  INPATIENT
}

enum RefundStatus {
  REQUESTED
  SUCCESS
  FAILED
  CANCELLED
}

enum PrescriptionStatus {
  DRAFT
  SUBMITTED
  REJECTED
  REVIEWED
  DISPENSED
  CANCELLED
}

enum EncounterStatus {
  OPEN
  COMPLETED
  CANCELLED
}

enum PatientNotificationType {
  APPOINTMENT
  QUEUE
  FOLLOW_UP
  SYSTEM
}

enum QueueTicketStatus {
  WAITING
  CALLED
  SKIPPED
  COMPLETED
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  PAY
  CANCEL
}

enum DrugStockMovementType {
  RECEIVE
  ADJUST
  DAMAGE
  DISPENSE
  RETURN
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  CLEANING
  MAINTENANCE
  DISABLED
}

enum InpatientAdmissionStatus {
  PENDING
  ADMITTED
  DISCHARGE_REQUESTED
  DISCHARGE_APPROVED
  SETTLED
  DISCHARGED
  CANCELLED
}

enum BedAssignmentStatus {
  ACTIVE
  RELEASED
}

enum InpatientOrderStatus {
  ACTIVE
  STOPPED
  CANCELLED
}

enum InpatientChargeStatus {
  UNBILLED
  BILLED
  CANCELLED
}

enum DischargeRequestStatus {
  REQUESTED
  APPROVED
  SETTLED
  COMPLETED
  CANCELLED
}

model User {
  id             String          @id @default(cuid())
  username       String          @unique @db.VarChar(64)
  phone          String?         @unique @db.VarChar(20)
  email          String?         @unique @db.VarChar(120)
  passwordHash   String          @db.VarChar(255)
  displayName    String          @db.VarChar(80)
  status         UserStatus      @default(ACTIVE)
  lastLoginAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  roles          UserRole[]
  doctorProfile  DoctorProfile?
  patientProfile PatientProfile?
  paymentOrders  PaymentOrder[]
  registrations  Registration[]
  auditLogs      AuditLog[]
  scheduleChangeLogs     ScheduleChangeLog[]
  registrationChangeLogs RegistrationChangeLog[]
  lockedSlots    AppointmentSlot[] @relation("SlotLockOwner")
  requestedRefunds RefundOrder[]
  drugStockMovements DrugStockMovement[]
  prescriptionReviewLogs PrescriptionReviewLog[]
  notifications PatientNotification[]
  favoriteDoctors FavoriteDoctor[]
  inpatientAdmissions InpatientAdmission[] @relation("InpatientPatientUser")
  dischargeApprovals DischargeRequest[] @relation("DischargeApprover")
}

model Role {
  id          String           @id @default(cuid())
  code        String           @unique @db.VarChar(64)
  name        String           @db.VarChar(80)
  description String?          @db.VarChar(255)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id        String           @id @default(cuid())
  code      String           @unique @db.VarChar(120)
  name      String           @db.VarChar(120)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  roles     RolePermission[]
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Menu {
  id        String   @id @default(cuid())
  code      String   @unique @db.VarChar(80)
  title     String   @db.VarChar(80)
  path      String   @db.VarChar(160)
  icon      String?  @db.VarChar(80)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  parentId  String?
  parent    Menu?    @relation("MenuTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Menu[]   @relation("MenuTree")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HospitalCampus {
  id          String       @id @default(cuid())
  name        String       @unique @db.VarChar(120)
  address     String       @db.VarChar(255)
  phone       String?      @db.VarChar(30)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  departments Department[]
  clinicRooms ClinicRoom[]
  wards       Ward[]
}

model Department {
  id            String           @id @default(cuid())
  campusId      String
  name          String           @db.VarChar(120)
  code          String           @unique @db.VarChar(64)
  summary       String?          @db.VarChar(500)
  isActive      Boolean          @default(true)
  sortOrder     Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  campus        HospitalCampus   @relation(fields: [campusId], references: [id])
  clinicRooms   ClinicRoom[]
  doctors       DoctorProfile[]
  schedules     DoctorSchedule[]
  scheduleTemplates ScheduleTemplate[]
  registrations Registration[]
  queueTickets QueueTicket[]
}

model ClinicRoom {
  id           String          @id @default(cuid())
  campusId     String
  departmentId String
  name         String          @db.VarChar(120)
  floor        String?         @db.VarChar(40)
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  campus       HospitalCampus  @relation(fields: [campusId], references: [id])
  department   Department      @relation(fields: [departmentId], references: [id])
  schedules    DoctorSchedule[]
  scheduleTemplates ScheduleTemplate[]
}

model DoctorProfile {
  id             String           @id @default(cuid())
  userId         String           @unique
  departmentId   String
  employeeNo     String           @unique @db.VarChar(64)
  title          String           @db.VarChar(80)
  specialty      String           @db.VarChar(255)
  introduction   String?          @db.VarChar(1000)
  licenseNo      String?          @db.VarChar(120)
  avatarUrl      String?          @db.VarChar(500)
  consultationFee Decimal         @default(20.00) @db.Decimal(10, 2)
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation(fields: [userId], references: [id])
  department     Department       @relation(fields: [departmentId], references: [id])
  schedules      DoctorSchedule[]
  scheduleTemplates ScheduleTemplate[]
  registrations  Registration[]
  encounters     Encounter[]
  prescriptions  Prescription[]
  queueTickets   QueueTicket[]
  queueState     DoctorQueueState?
  favoritedBy    FavoriteDoctor[]
  inpatientAdmissions InpatientAdmission[]
  inpatientRecords InpatientMedicalRecord[]
  inpatientOrders InpatientOrder[]
  dischargeRequests DischargeRequest[]
}

model PatientProfile {
  id           String        @id @default(cuid())
  userId       String        @unique
  patientNo    String        @unique @db.VarChar(64)
  realName     String        @db.VarChar(80)
  gender       String?       @db.VarChar(20)
  birthday     DateTime?
  idCardNo     String?       @db.VarChar(32)
  phone        String?       @db.VarChar(30)
  healthNote   String?       @db.VarChar(500)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id])
  visitMembers VisitMember[]
}

model VisitMember {
  id              String         @id @default(cuid())
  patientId       String
  name            String         @db.VarChar(80)
  gender          String?        @db.VarChar(20)
  birthday        DateTime?
  idCardNo        String?        @db.VarChar(32)
  phone           String?        @db.VarChar(30)
  relationship    String         @default("SELF") @db.VarChar(40)
  isDefault       Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  patient         PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  registrations   Registration[]
  inpatientAdmissions InpatientAdmission[]
}

model DoctorSchedule {
  id           String            @id @default(cuid())
  doctorId     String
  departmentId String
  clinicRoomId String?
  workDate     DateTime
  period        String            @db.VarChar(40)
  capacity      Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  doctor        DoctorProfile     @relation(fields: [doctorId], references: [id])
  department    Department        @relation(fields: [departmentId], references: [id])
  clinicRoom    ClinicRoom?       @relation(fields: [clinicRoomId], references: [id], onDelete: SetNull)
  slots         AppointmentSlot[]
  changeLogs    ScheduleChangeLog[]
}

model ScheduleTemplate {
  id           String                 @id @default(cuid())
  name         String                 @db.VarChar(120)
  doctorId     String
  departmentId String
  clinicRoomId String?
  period       String                 @db.VarChar(40)
  capacity     Int                    @default(0)
  isActive     Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  doctor       DoctorProfile          @relation(fields: [doctorId], references: [id])
  department   Department             @relation(fields: [departmentId], references: [id])
  clinicRoom   ClinicRoom?            @relation(fields: [clinicRoomId], references: [id], onDelete: SetNull)
  rules        ScheduleTemplateRule[]
}

model ScheduleTemplateRule {
  id         String           @id @default(cuid())
  templateId String
  weekday    Int
  startTime  String           @db.VarChar(10)
  endTime    String           @db.VarChar(10)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  template   ScheduleTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model ScheduleChangeLog {
  id         String         @id @default(cuid())
  scheduleId String
  action     String         @db.VarChar(80)
  reason     String?        @db.VarChar(500)
  userId     String?
  createdAt  DateTime       @default(now())
  schedule   DoctorSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user       User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model RegistrationChangeLog {
  id             String       @id @default(cuid())
  registrationId String
  action         String       @db.VarChar(80)
  reason         String?      @db.VarChar(500)
  fromSlotId     String?
  toSlotId       String?
  userId         String?
  createdAt      DateTime     @default(now())
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  fromSlot       AppointmentSlot? @relation("RegistrationChangeFromSlot", fields: [fromSlotId], references: [id], onDelete: SetNull)
  toSlot         AppointmentSlot? @relation("RegistrationChangeToSlot", fields: [toSlotId], references: [id], onDelete: SetNull)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model AppointmentSlot {
  id             String                @id @default(cuid())
  scheduleId     String
  startTime      DateTime
  endTime        DateTime
  fee            Decimal               @default(20.00) @db.Decimal(10, 2)
  status         AppointmentSlotStatus @default(AVAILABLE)
  lockedUntil    DateTime?
  lockedByUserId String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  schedule       DoctorSchedule        @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  lockedByUser   User?                 @relation("SlotLockOwner", fields: [lockedByUserId], references: [id], onDelete: SetNull)
  registration   Registration?
  fromRegistrationChangeLogs RegistrationChangeLog[] @relation("RegistrationChangeFromSlot")
  toRegistrationChangeLogs   RegistrationChangeLog[] @relation("RegistrationChangeToSlot")
}

model Registration {
  id             String             @id @default(cuid())
  registrationNo String             @unique @db.VarChar(64)
  status         RegistrationStatus @default(BOOKED)
  userId         String
  visitMemberId  String
  departmentId   String
  doctorId       String
  slotId         String             @unique
  paymentOrderId String?            @unique
  checkedInAt    DateTime?
  cancelledAt    DateTime?
  noShowAt       DateTime?
  noShowReason   String?            @db.VarChar(500)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User               @relation(fields: [userId], references: [id])
  visitMember    VisitMember        @relation(fields: [visitMemberId], references: [id])
  department     Department         @relation(fields: [departmentId], references: [id])
  doctor         DoctorProfile      @relation(fields: [doctorId], references: [id])
  slot           AppointmentSlot    @relation(fields: [slotId], references: [id])
  paymentOrder   PaymentOrder?      @relation(fields: [paymentOrderId], references: [id], onDelete: SetNull)
  encounter      Encounter?
  changeLogs     RegistrationChangeLog[]
  queueTicket    QueueTicket?
}

model PatientNotification {
  id         String                  @id @default(cuid())
  userId     String
  type       PatientNotificationType @default(SYSTEM)
  title      String                  @db.VarChar(160)
  content    String                  @db.VarChar(1000)
  sourceType String?                 @db.VarChar(80)
  sourceId   String?                 @db.VarChar(120)
  readAt     DateTime?
  createdAt  DateTime                @default(now())
  user       User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model QueueTicket {
  id             String            @id @default(cuid())
  registrationId String            @unique
  doctorId       String
  departmentId   String
  queueNo        Int
  status         QueueTicketStatus @default(WAITING)
  calledAt       DateTime?
  skippedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  registration   Registration      @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  doctor         DoctorProfile     @relation(fields: [doctorId], references: [id])
  department     Department        @relation(fields: [departmentId], references: [id])

  @@unique([doctorId, queueNo])
  @@index([doctorId, status, queueNo])
}

model DoctorQueueState {
  id              String        @id @default(cuid())
  doctorId        String        @unique
  currentTicketId String?
  avgMinutes      Int           @default(8)
  updatedAt       DateTime      @updatedAt
  doctor          DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model FavoriteDoctor {
  id        String        @id @default(cuid())
  userId    String
  doctorId  String
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctor    DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([userId, doctorId])
}

model Encounter {
  id             String         @id @default(cuid())
  registrationId String         @unique
  doctorId       String
  chiefComplaint String?        @db.VarChar(500)
  status         EncounterStatus @default(OPEN)
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  registration   Registration   @relation(fields: [registrationId], references: [id])
  doctor         DoctorProfile  @relation(fields: [doctorId], references: [id])
  medicalRecord  MedicalRecord?
  diagnoses      Diagnosis[]
  medicalOrders  MedicalOrder[]
  prescriptions  Prescription[]
}

model MedicalRecord {
  id          String    @id @default(cuid())
  encounterId String    @unique
  summary     String    @db.VarChar(1000)
  advice      String?   @db.VarChar(1000)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  encounter   Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
}

model Diagnosis {
  id          String    @id @default(cuid())
  encounterId String
  code        String?   @db.VarChar(64)
  name        String    @db.VarChar(120)
  note        String?   @db.VarChar(500)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  encounter   Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
}

model MedicalOrder {
  id          String    @id @default(cuid())
  encounterId String
  type        String    @db.VarChar(80)
  content     String    @db.VarChar(500)
  status      String    @default("ACTIVE") @db.VarChar(40)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  encounter   Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
}

model FeeItem {
  id          String   @id @default(cuid())
  code        String   @unique @db.VarChar(64)
  name        String   @db.VarChar(120)
  amount      Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  inpatientCharges InpatientCharge[]
}

model PaymentOrder {
  id             String        @id @default(cuid())
  orderNo        String        @unique @db.VarChar(64)
  title          String        @db.VarChar(160)
  amount         Decimal       @db.Decimal(10, 2)
  businessType   PaymentBusinessType @default(REGISTRATION)
  sourceType     String?       @db.VarChar(80)
  sourceId       String?       @db.VarChar(120)
  payMethod      String?       @db.VarChar(40)
  status         PaymentStatus @default(PENDING)
  userId         String
  paidAt         DateTime?
  cancelledAt    DateTime?
  refundedAt     DateTime?
  refundLockedAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id])
  registration   Registration?
  items          PaymentOrderItem[]
  transactions   PaymentTransaction[]
  refundOrders   RefundOrder[]
  settlements    PaymentSettlement[]
  inpatientCharges InpatientCharge[]
}

model Ward {
  id           String         @id @default(cuid())
  campusId     String
  code         String         @unique @db.VarChar(64)
  name         String         @db.VarChar(120)
  floor        String?        @db.VarChar(40)
  nurseStation String?        @db.VarChar(120)
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  campus       HospitalCampus @relation(fields: [campusId], references: [id])
  beds         Bed[]
  admissions   InpatientAdmission[]
}

model Bed {
  id                  String               @id @default(cuid())
  wardId              String
  bedNo               String               @db.VarChar(40)
  status              BedStatus            @default(AVAILABLE)
  dailyRate           Decimal              @default(0.00) @db.Decimal(10, 2)
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  ward                Ward                 @relation(fields: [wardId], references: [id])
  assignments         BedAssignment[]
  currentAdmissions   InpatientAdmission[] @relation("CurrentBed")

  @@unique([wardId, bedNo])
  @@index([wardId, status])
}

model InpatientAdmission {
  id                String                   @id @default(cuid())
  admissionNo       String                   @unique @db.VarChar(80)
  status            InpatientAdmissionStatus @default(PENDING)
  userId            String
  visitMemberId     String
  attendingDoctorId String?
  wardId            String?
  currentBedId      String?
  diagnosis         String?                  @db.VarChar(500)
  notes             String?                  @db.VarChar(1000)
  depositAmount     Decimal                  @default(0.00) @db.Decimal(10, 2)
  bedVersion        Int                      @default(0)
  admittedAt        DateTime?
  dischargedAt      DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  user              User                     @relation("InpatientPatientUser", fields: [userId], references: [id])
  visitMember       VisitMember              @relation(fields: [visitMemberId], references: [id])
  attendingDoctor   DoctorProfile?           @relation(fields: [attendingDoctorId], references: [id], onDelete: SetNull)
  ward              Ward?                    @relation(fields: [wardId], references: [id], onDelete: SetNull)
  currentBed        Bed?                     @relation("CurrentBed", fields: [currentBedId], references: [id], onDelete: SetNull)
  bedAssignments    BedAssignment[]
  medicalRecords    InpatientMedicalRecord[]
  orders            InpatientOrder[]
  charges           InpatientCharge[]
  dischargeRequests DischargeRequest[]

  @@index([userId, status, createdAt])
  @@index([visitMemberId, status])
}

model BedAssignment {
  id          String              @id @default(cuid())
  admissionId String
  bedId       String
  status      BedAssignmentStatus @default(ACTIVE)
  assignedAt  DateTime            @default(now())
  releasedAt  DateTime?
  reason      String?             @db.VarChar(500)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  admission   InpatientAdmission  @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  bed         Bed                 @relation(fields: [bedId], references: [id])

  @@index([admissionId, status])
  @@index([bedId, status])
}

model InpatientMedicalRecord {
  id          String             @id @default(cuid())
  admissionId String
  doctorId    String?
  summary     String             @db.VarChar(1000)
  plan        String?            @db.VarChar(1000)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  admission   InpatientAdmission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  doctor      DoctorProfile?     @relation(fields: [doctorId], references: [id], onDelete: SetNull)
}

model InpatientOrder {
  id          String               @id @default(cuid())
  admissionId String
  doctorId    String
  type        String               @db.VarChar(80)
  content     String               @db.VarChar(500)
  status      InpatientOrderStatus @default(ACTIVE)
  startedAt   DateTime             @default(now())
  stoppedAt   DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  admission   InpatientAdmission   @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  doctor      DoctorProfile        @relation(fields: [doctorId], references: [id])
  charges     InpatientCharge[]

  @@index([admissionId, status])
}

model InpatientCharge {
  id             String                @id @default(cuid())
  admissionId    String
  orderId        String?
  feeItemId      String?
  paymentOrderId String?
  itemName       String                @db.VarChar(160)
  quantity       Int                   @default(1)
  unitPrice      Decimal               @db.Decimal(10, 2)
  amount         Decimal               @db.Decimal(10, 2)
  status         InpatientChargeStatus @default(UNBILLED)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  admission      InpatientAdmission    @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  order          InpatientOrder?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  feeItem        FeeItem?              @relation(fields: [feeItemId], references: [id], onDelete: SetNull)
  paymentOrder   PaymentOrder?         @relation(fields: [paymentOrderId], references: [id], onDelete: SetNull)

  @@index([admissionId, status])
  @@index([paymentOrderId])
}

model DischargeRequest {
  id                  String                 @id @default(cuid())
  admissionId         String
  requestedByDoctorId String?
  approvedByUserId    String?
  status              DischargeRequestStatus @default(REQUESTED)
  reason              String                 @db.VarChar(500)
  approvalNote        String?                @db.VarChar(500)
  requestedAt         DateTime               @default(now())
  approvedAt          DateTime?
  settledAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  admission           InpatientAdmission     @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  requestedByDoctor   DoctorProfile?         @relation(fields: [requestedByDoctorId], references: [id], onDelete: SetNull)
  approvedBy          User?                  @relation("DischargeApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([admissionId, status])
}

model PaymentOrderItem {
  id             String       @id @default(cuid())
  paymentOrderId String
  itemType       String       @db.VarChar(64)
  itemName       String       @db.VarChar(160)
  quantity       Int          @default(1)
  unitPrice      Decimal      @db.Decimal(10, 2)
  amount         Decimal      @db.Decimal(10, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  paymentOrder   PaymentOrder @relation(fields: [paymentOrderId], references: [id], onDelete: Cascade)
}

model PaymentTransaction {
  id              String       @id @default(cuid())
  paymentOrderId  String
  transactionNo   String       @unique @db.VarChar(80)
  providerTradeNo String?      @db.VarChar(120)
  payMethod       String       @db.VarChar(40)
  amount          Decimal      @db.Decimal(10, 2)
  status          String       @db.VarChar(40)
  raw             Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  paymentOrder    PaymentOrder @relation(fields: [paymentOrderId], references: [id], onDelete: Cascade)
}

model RefundOrder {
  id             String              @id @default(cuid())
  paymentOrderId String
  refundNo       String              @unique @db.VarChar(80)
  amount         Decimal             @db.Decimal(10, 2)
  reason         String              @db.VarChar(500)
  status         RefundStatus         @default(REQUESTED)
  requestedById  String?
  executedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  paymentOrder   PaymentOrder        @relation(fields: [paymentOrderId], references: [id], onDelete: Cascade)
  requestedBy    User?               @relation(fields: [requestedById], references: [id], onDelete: SetNull)
  transactions   RefundTransaction[]
}

model RefundTransaction {
  id               String      @id @default(cuid())
  refundOrderId     String
  transactionNo     String      @unique @db.VarChar(80)
  providerRefundNo  String?     @db.VarChar(120)
  amount            Decimal     @db.Decimal(10, 2)
  status            String      @db.VarChar(40)
  raw               Json?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  refundOrder       RefundOrder @relation(fields: [refundOrderId], references: [id], onDelete: Cascade)
}

model PaymentSettlement {
  id             String       @id @default(cuid())
  paymentOrderId String
  settlementNo   String       @unique @db.VarChar(80)
  amount         Decimal      @db.Decimal(10, 2)
  status         String       @db.VarChar(40)
  settledAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  paymentOrder   PaymentOrder @relation(fields: [paymentOrderId], references: [id], onDelete: Cascade)
}

model DrugCatalog {
  id          String             @id @default(cuid())
  code        String             @unique @db.VarChar(64)
  name        String             @db.VarChar(160)
  spec        String             @db.VarChar(120)
  unit        String             @db.VarChar(40)
  price       Decimal            @db.Decimal(10, 2)
  minStock    Int                @default(0)
  requiresBatch Boolean          @default(true)
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  items       PrescriptionItem[]
  stockBatches DrugStockBatch[]
  stockMovements DrugStockMovement[]
  stockAlerts DrugStockAlert[]
  prescriptionTemplateItems PrescriptionTemplateItem[]
}

model MedicalRecordTemplate {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(120)
  summary   String   @db.VarChar(1000)
  advice    String?  @db.VarChar(1000)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommonDiagnosis {
  id        String   @id @default(cuid())
  code      String?  @db.VarChar(64)
  name      String   @db.VarChar(120)
  note      String?  @db.VarChar(500)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommonMedicalOrder {
  id        String   @id @default(cuid())
  type      String   @db.VarChar(80)
  content   String   @db.VarChar(500)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PrescriptionTemplate {
  id        String                     @id @default(cuid())
  name      String                     @db.VarChar(120)
  note      String?                    @db.VarChar(500)
  isActive  Boolean                    @default(true)
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt
  items     PrescriptionTemplateItem[]
}

model PrescriptionTemplateItem {
  id         String               @id @default(cuid())
  templateId String
  drugId     String
  quantity   Int
  dosage     String               @db.VarChar(120)
  usage      String               @db.VarChar(120)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  template   PrescriptionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  drug       DrugCatalog          @relation(fields: [drugId], references: [id])

  @@unique([templateId, drugId])
}

model DrugStockBatch {
  id          String              @id @default(cuid())
  drugId      String
  batchNo     String              @db.VarChar(80)
  quantity    Int                 @default(0)
  expiresAt   DateTime
  receivedAt  DateTime            @default(now())
  unitCost    Decimal?            @db.Decimal(10, 2)
  supplier    String?             @db.VarChar(160)
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  drug        DrugCatalog         @relation(fields: [drugId], references: [id], onDelete: Cascade)
  movements   DrugStockMovement[]
  alerts      DrugStockAlert[]

  @@unique([drugId, batchNo])
  @@index([drugId, expiresAt])
}

model DrugStockMovement {
  id             String                 @id @default(cuid())
  batchId        String
  drugId         String
  prescriptionId String?
  type           DrugStockMovementType
  quantity       Int
  beforeQuantity Int
  afterQuantity  Int
  reason         String?                @db.VarChar(500)
  operatorId     String?
  createdAt      DateTime               @default(now())
  batch          DrugStockBatch         @relation(fields: [batchId], references: [id], onDelete: Restrict)
  drug           DrugCatalog            @relation(fields: [drugId], references: [id], onDelete: Restrict)
  prescription   Prescription?          @relation(fields: [prescriptionId], references: [id], onDelete: SetNull)
  operator       User?                  @relation(fields: [operatorId], references: [id], onDelete: SetNull)

  @@index([drugId, createdAt])
  @@index([prescriptionId])
}

model DrugStockAlert {
  id          String       @id @default(cuid())
  drugId      String
  batchId     String?
  type        String       @db.VarChar(40)
  level       String       @default("WARNING") @db.VarChar(40)
  message     String       @db.VarChar(500)
  isResolved  Boolean      @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  drug        DrugCatalog  @relation(fields: [drugId], references: [id], onDelete: Cascade)
  batch       DrugStockBatch? @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([drugId, isResolved])
}

model Prescription {
  id          String             @id @default(cuid())
  encounterId String?
  doctorId    String
  status      PrescriptionStatus @default(DRAFT)
  note        String?            @db.VarChar(500)
  rejectedReason String?         @db.VarChar(500)
  rejectedAt  DateTime?
  resubmittedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  encounter   Encounter?         @relation(fields: [encounterId], references: [id], onDelete: SetNull)
  doctor      DoctorProfile      @relation(fields: [doctorId], references: [id])
  items       PrescriptionItem[]
  stockMovements DrugStockMovement[]
  reviewLogs  PrescriptionReviewLog[]
}

model PrescriptionItem {
  id             String       @id @default(cuid())
  prescriptionId String
  drugId         String
  quantity       Int
  dosage         String       @db.VarChar(120)
  usage          String       @db.VarChar(120)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  drug           DrugCatalog  @relation(fields: [drugId], references: [id])
}

model PrescriptionReviewLog {
  id             String       @id @default(cuid())
  prescriptionId String
  action         String       @db.VarChar(40)
  fromStatus     PrescriptionStatus?
  toStatus       PrescriptionStatus
  reason         String?      @db.VarChar(500)
  reviewerId     String?
  createdAt      DateTime     @default(now())
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  reviewer       User?        @relation(fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([prescriptionId, createdAt])
}

model Announcement {
  id          String   @id @default(cuid())
  title       String   @db.VarChar(160)
  content     String   @db.VarChar(1000)
  isActive    Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DictionaryCategory {
  id          String           @id @default(cuid())
  code        String           @unique @db.VarChar(80)
  name        String           @db.VarChar(120)
  description String?          @db.VarChar(255)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  items       DictionaryItem[]
}

model DictionaryItem {
  id         String             @id @default(cuid())
  categoryId String
  code       String             @db.VarChar(80)
  label      String             @db.VarChar(120)
  sortOrder  Int                @default(0)
  isActive   Boolean            @default(true)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  category   DictionaryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, code])
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  action    AuditAction
  resource  String      @db.VarChar(120)
  resourceId String?    @db.VarChar(120)
  detail    String?     @db.VarChar(1000)
  ip        String?     @db.VarChar(80)
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
}
