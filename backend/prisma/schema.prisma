// ═══════════════════════════════════════════════════════════════════
// Module: 设备管理
// ═══════════════════════════════════════════════════════════════════

enum EquipmentStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  CALIBRATION
  RETIRED
}

model Equipment {
  id             String          @id @default(cuid())
  code           String          @unique @db.VarChar(32)
  name           String          @db.VarChar(120)
  category       String          @db.VarChar(60)
  model          String?         @db.VarChar(80)
  manufacturer   String?         @db.VarChar(120)
  serialNo       String?         @db.VarChar(80)
  departmentId   String?
  location       String?         @db.VarChar(120)
  status         EquipmentStatus @default(AVAILABLE)
  purchaseDate   DateTime?
  warrantyExpiry DateTime?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  department     Department?     @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  maintenanceRecords EquipmentMaintenance[]

  @@index([departmentId])
  @@index([status])
  @@index([category])
}

model EquipmentMaintenance {
  id            String   @id @default(cuid())
  equipmentId   String
  maintenanceType String @db.VarChar(30) // SCHEDULED / REPAIR / CALIBRATION
  description   String   @db.Text
  cost          Decimal? @db.Decimal(10, 2)
  performedBy   String?
  performedAt   DateTime @default(now())
  nextDueDate   DateTime?
  equipment     Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@index([maintenanceType])
}

model EquipmentUsageLog {
  id            String   @id @default(cuid())
  equipmentId   String
  usedBy        String?
  departmentId  String?
  purpose       String?  @db.VarChar(200)
  startTime     DateTime
  endTime       DateTime?
  notes         String?  @db.VarChar(500)

  @@index([equipmentId])
  @@index([startTime])
}
